# /fukaya-lab-server/OruCa/justfile (新規作成)

_default:
	@just -l

# --- 🛠️ OruCa ビルドタスク ---
# ルートの 'build' メタタスクから 'OruCa::build' として呼び出されます。
build:
    @echo "🛠️ Building OruCa frontend application..."
    @docker compose -f ../docker-compose.yml \
        --profile dev run --rm oruca-vite yarn build
    @echo "✅ OruCa Frontend built to ./vite/dist/"


# --- 📦 OruCa 固有タスク ---
# 'just OruCa::usb' のように呼び出します。

# (WSL用) OruCaのNFCリーダーをWSLにアタッチします
# (OruCa/Makefile の 'attach-usb' から移植)
usb:
    @echo "🔌 Attaching USB FeliCa Reader to WSL..."
    @powershell.exe -ExecutionPolicy Bypass -File ./usb-wsl-attach.ps1
    @echo "✅ USB device attached."

# OruCaのDBバックアップを保存します(例: just OruCa::backup)
# OruCaのDBバックアップを保存します(例: just OruCa::backup)
backup:
  @echo "💾 Saving OruCa MySQL backup..."
  @docker compose -f ../docker-compose.yml \
    exec oruca-mysql sh -c "\
     TARGET_DIR=/backups/$(date +%Y%m%d-%H%M%S); \
     mkdir -p \"\${TARGET_DIR}\" && \
     mysqldump --no-tablespaces -u\${MYSQL_USER} -p\${MYSQL_PASSWORD} \${MYSQL_DATABASE} > \"\${TARGET_DIR}/backup.sql\""
  @echo "✅ Backup created in OruCa mysql volume's /backups directory."

# OruCaのDBバックアップをリストアします (例: just OruCa::restore YYYYMMDD-HHMMSS)
restore BACKUP_DATE:
    @echo "🔄 Restoring OruCa MySQL backup from {{BACKUP_DATE}}..."
    @docker compose -f ../docker-compose.yml \
        exec -T oruca-mysql sh -c "mysql -u'root' -p${MYSQL_ROOT_PASSWORD} ${MYSQL_DATABASE} < /backups/{{BACKUP_DATE}}/backup.sql"
    @echo "✅ Restore complete."
